# ═══════════════════════════════════════════════════════════════════
# TOMBSTONE — Environment Configuration
# Autonomous Product Deprecation & UI Entropy Optimization Engine
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and replace placeholder values.
# .env is gitignored. .env.example is committed.
# All keys are accessed exclusively via src/config/env.ts.
# NEVER hardcode API keys, tokens, or SDK IDs in source files.
# ═══════════════════════════════════════════════════════════════════

# ── Novus / Pendo Telemetry ──────────────────────────────────────
# Pendo SDK Application ID for interaction tracking.
# Obtain from: Pendo → Settings → Subscription → App ID
# If absent, the app boots with a console warning but does not crash.
VITE_PENDO_APP_ID=your_pendo_app_id_here

# ── MCP Code-Diff Generation Endpoint ────────────────────────────
# Optional edge function or proxy for AI-driven code diff generation.
# Used by the Commit Obsequies terminal to generate richer diffs.
# If absent, diffs are generated client-side from node metadata.
VITE_MCP_ENDPOINT=https://your-edge-proxy.vercel.app/api/diff

# ── JSON-LD Export Signing Key ───────────────────────────────────
# Optional signing key for authenticated Tombstone schema exports.
# Used to sign JSON-LD documents for provenance verification.
# If absent, schemas are exported unsigned.
VITE_SCHEMA_SIGNING_KEY=your_signing_key_here
